{
 "compilerOptions": {
  "target": "ES2020",
  "module": "commonjs",
  "rootDir": "./",
  "outDir": "./dist",
  "esModuleInterop": true,
  "strict": false,
  "skipLibCheck": true,
  "forceConsistentCasingInFileNames": true,
  "resolveJsonModule": true,
  "sourceMap": false,
  "declaration": false,
  "incremental": false
 },
 "include": [
  "**/*.ts"
 ],
 "exclude": [
  "node_modules",
  "dist",
  "frontend",
  "uploads",
  "logs",
  "scripts",
  "**/*.test.ts"
 ]
}
