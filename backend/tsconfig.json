{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",

    "rootDir": ".",
    "outDir": "dist",

    "moduleResolution": "node",

    "strict": false,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,

    "sourceMap": false,
    "declaration": false,
    "incremental": false
  },

  "include": [
    "**/*.ts"
  ],

  "exclude": [
    "node_modules",
    "dist",
    "frontend",
    "uploads",
    "logs",
    "scripts",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}